# ============================================================
# VC VALIDATION AGENT — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# === MASUMI NETWORK (REQUIRED for marketplace payments) ===
# Run Masumi Payment Service locally via Docker:
#   https://github.com/masumi-network/masumi-services-dev-quickstart
# Or deploy on Railway:
#   https://docs.masumi.network/documentation/get-started/installation
PAYMENT_SERVICE_URL=http://localhost:3001/api/v1
PAYMENT_API_KEY=your_masumi_payment_api_key_from_dashboard
AGENT_IDENTIFIER=your_agent_identifier_after_registration
SELLER_VKEY=your_selling_wallet_verification_key
NETWORK=Preprod

# === LLM API (REQUIRED — at least one) ===
# Claude API (primary) — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...
# OpenAI (optional fallback) — get key at https://platform.openai.com
OPENAI_API_KEY=sk-...

# === REDDIT API (OPTIONAL - for sentiment analysis) ===
# The agent works without Reddit, but it enhances market research
# Create a Reddit app at https://www.reddit.com/prefs/apps (requires approval)
# Select "script" type. Use http://localhost as redirect URI.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=vc-validation-agent/1.0

# === WEB SEARCH (REQUIRED — pick one) ===
# SerperDev — https://serper.dev (2,500 free queries)
SERPER_API_KEY=your_serper_dev_api_key
# OR SerpApi — https://serpapi.com (100 free queries/month)
SERPAPI_API_KEY=your_serpapi_key

# === DEVELOPMENT ===
# Set to true to skip payment verification during local testing
DEV_MODE=false
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Server host and port
HOST=0.0.0.0
PORT=8000
