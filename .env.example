# ============================================================
# VC VALIDATION AGENT — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# === MASUMI NETWORK (REQUIRED for marketplace payments) ===
# Run Masumi Payment Service locally via Docker:
#   https://github.com/masumi-network/masumi-services-dev-quickstart
# Or deploy on Railway:
#   https://docs.masumi.network/documentation/get-started/installation
PAYMENT_SERVICE_URL=http://localhost:3001/api/v1
PAYMENT_API_KEY=your_masumi_payment_api_key_from_dashboard
AGENT_IDENTIFIER=your_agent_identifier_after_registration
SELLER_VKEY=your_selling_wallet_verification_key
NETWORK=Preprod

# === LLM API (REQUIRED — at least one) ===
# Claude API (primary) — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...
# Claude model (optional) — use a current Anthropic alias unless you need a pinned snapshot
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# OpenAI (optional fallback) — get key at https://platform.openai.com
OPENAI_API_KEY=sk-...

# === WEB SEARCH (REQUIRED — pick one) ===
# SerperDev — https://serper.dev (2,500 free queries)
SERPER_API_KEY=your_serper_dev_api_key
# OR SerpApi — https://serpapi.com (100 free queries/month)
SERPAPI_API_KEY=your_serpapi_key

# === EXPANDED RESEARCH SIGNALS (OPTIONAL, RECOMMENDED) ===
# NewsAPI — https://newsapi.org
# Used for recent market coverage, launch/news momentum, and sector narrative
NEWSAPI_API_KEY=

# GitHub Personal Access Token — https://github.com/settings/tokens
# Optional: public search works without it, but a token improves rate limits and reliability
GITHUB_TOKEN=

# YouTube Data API v3 — https://developers.google.com/youtube/v3/getting-started
# Used for creator discourse and video-level market signal
YOUTUBE_API_KEY=

# Similarweb API — https://developers.similarweb.com
# Used for competitor traffic/rank benchmarks when you have website domains
SIMILARWEB_API_KEY=

# === FUTURE PREMIUM DILIGENCE SIGNALS (PLACEHOLDERS) ===
# Crunchbase API — https://support.crunchbase.com
# For startup comps, funding rounds, and investor activity
CRUNCHBASE_API_KEY=

# Google Ads API — https://developers.google.com/google-ads/api
# For keyword demand sizing with average monthly search volume and competition metrics
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# === DEVELOPMENT ===
# Set to true to skip payment verification during local testing
DEV_MODE=false
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Server host and port
HOST=0.0.0.0
PORT=8000
